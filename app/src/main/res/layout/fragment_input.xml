<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/es_li_background">

    <EditText
        android:id="@+id/es_li_et_income"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/es_li_income_hint"
        android:inputType="numberDecimal"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/es_li_et_expenses"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/es_li_expenses_hint"
        android:inputType="numberDecimal"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/es_li_et_income"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/es_li_btn_save"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/es_li_save_button"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/es_li_et_expenses"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>